{
  "name": "@workspace/api-server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "node scripts/patch-fca.js",
    "dev": "node scripts/patch-fca.js && export NODE_ENV=development && npx ts-node -r tsconfig-paths/register src/index.ts",
    "build": "node scripts/patch-fca.js && node_modules/.bin/tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.10",
    "@dongdev/fca-unofficial": "4.0.3",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@types/mongoose": "^5.11.96",
    "axios": "^1.16.0",
    "chokidar": "^3.6.0",
    "dotenv": "^16.6.0",
    "express": "^4.21.2",
    "fca-unofficial-fixed": "^1.0.20",
    "fluent-ffmpeg": "^2.1.3",
    "mongoose": "^9.6.0",
    "uuid": "^11.1.0",
    "youtube-search-api": "^1.1.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.42",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "gradient-string": "2.0.2",
    "form-data": "4.0.4"
  }
}
