{
  "name": "sixsu-messenger-bot",
  "version": "1.0.0",
  "description": "Facebook Messenger Bot - Clean TypeScript Architecture",
  "main": "dist/index.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "start": "node --enable-source-maps dist/index.js",
    "start:prod": "NODE_ENV=production node --enable-source-maps dist/index.js",
    "dev": "nodemon",
    "typecheck": "tsc --noEmit",

    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop sixsu-bot",
    "pm2:restart": "pm2 restart sixsu-bot",
    "pm2:reload": "pm2 reload ecosystem.config.js --env production",
    "pm2:delete": "pm2 delete sixsu-bot",
    "pm2:logs": "pm2 logs sixsu-bot",
    "pm2:status": "pm2 status",
    "pm2:save": "pm2 save",
    "pm2:monit": "pm2 monit",
    "pm2:startup": "pm2 startup",

    "deploy": "bash deploy.sh",
    "deploy:restart": "bash deploy.sh --restart",
    "deploy:status": "bash deploy.sh --status",
    "deploy:logs": "bash deploy.sh --logs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Sixseven-6677",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.16.1",
    "chokidar": "^3.6.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "mongoose": "^9.6.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/express": "^4.17.25",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^20.19.41",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.14",
    "pm2": "^5.4.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
