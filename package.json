{
  "name": "@workspace/api-server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "export NODE_ENV=development && npx ts-node -r tsconfig-paths/register src/index.ts",
    "build": "npx tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "chokidar": "^3.6.0",
    "dotenv": "^16.6.0",
    "express": "^4.21.2",
    "fca-unofficial": "^1.3.10",
    "mongoose": "^9.6.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/chokidar": "^1.7.5",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.3"
  }
}
